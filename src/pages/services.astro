---
import Layout from "../layouts/Layout.astro";
import Heading from "../components/ui/Heading.astro";
import Text from "../components/ui/Text.astro";
import Section from "../components/ui/Section.astro";
import SectionLabel from "../components/ui/SectionLabel.astro";
import CTAAboveFooter from "../components/CTAAboveFooter.astro";
import HeroSecondary from "../components/HeroSecondary.astro";
import { Check } from "lucide-astro";

interface ServiceFeature {
  title: string;
  description: string;
  features: string[];
  image: string;
}

const services: ServiceFeature[] = [
  {
    title: "Custom Business Website",
    description:
      "A professionally designed website built specifically for your business.",
    features: [
      "Looks great on phones and computers",
      "Simple, easy-to-use layout",
      "Fast loading pages",
      "Built to help turn visitors into calls and messages",
    ],
    image:
      "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80",
  },
  {
    title: "Google Visibility & Speed",
    description:
      "We set your site up to load quickly and be easy for Google to understand, so more people can find you.",
    features: [
      "Fast load times",
      "SEO basics set up the right way",
      "Clean page structure",
      "Simple traffic reports (so you know what's working)",
    ],
    image:
      "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80",
  },
  {
    title: "Website Care & Support",
    description:
      "We keep your website updated and running smoothly, and we're here when you need changes.",
    features: [
      "Security and maintenance updates",
      "Edits when you need them",
      "Quick fixes if something breaks",
      "Ongoing checkups to keep things running well",
    ],
    image:
      "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80",
  },
];
---

<Layout>

  <HeroSecondary
    label="Our Services"
    heading="Full-Service Web Solutions"
    description="From your first idea to launch day (and beyond), we take care of your website so you don't have to."
  />

  <Section>
    <div class="max-w-6xl mx-auto space-y-20">
      {
        services.map((service, index) => (
          <div
            class={`grid lg:grid-cols-2 gap-8 lg:gap-12 items-start ${index % 2 === 1 ? "lg:grid-flow-dense" : ""}`}
          >
            <div class={index % 2 === 1 ? "lg:col-start-2" : ""}>
              <h2 class="text-3xl lg:text-3xl font-bold text-navy mb-4 leading-tight">
                {service.title}
              </h2>
              <div class="h-1 w-12 bg-gold rounded-full mb-4" />
              <p class="text-lg text-slate-600 mb-8 leading-relaxed">
                {service.description}
              </p>

              <!-- Bullet box -->
              <div class="rounded-xl bg-white border border-slate-200 p-5">
                <ul class="space-y-3">
                  {service.features.map((feature) => (
                    <li class="flex items-start gap-3">
                      <Check class="h-5 w-5 text-teal shrink-0 mt-0.5" />
                      <span class="text-slate-700">{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <div class={index % 2 === 1 ? "lg:col-start-1 lg:row-start-1" : ""}>
              <div class="rounded-lg overflow-hidden shadow-md border border-slate-200">
                <img
                  src={service.image}
                  alt={service.title}
                  class="w-full object-cover aspect-4/3 max-h-56 sm:max-h-72 lg:max-h-none"
                />
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Section>

  <Section bg="light">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <SectionLabel>Why Small Businesses Choose Dockside</SectionLabel>
      <Heading>Everything Your Small Business Needs Online</Heading>
      <Text class="mt-4">
        We're not a faceless agency. When you call, you get the owner and
        developer directly. No project managers, no account reps—just honest
        communication and quality work.
      </Text>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-white p-8 rounded-xl shadow-sm border border-slate-200">
        <div class="text-4xl font-bold text-teal mb-2">3-4</div>
        <div class="text-sm font-semibold text-navy uppercase tracking-wide mb-2">
          Weeks
        </div>
        <p class="text-slate-600">
          Most projects launch in 3–4 weeks, depending on pages and content.
        </p>
      </div>

      <div class="bg-white p-8 rounded-xl shadow-sm border border-slate-200">
        <div class="text-4xl font-bold text-teal mb-2">98+</div>
        <div class="text-sm font-semibold text-navy uppercase tracking-wide mb-2">
          PageSpeed
        </div>
        <p class="text-slate-600">
          Every site we build aims to score above 98 on Google's performance metrics.
        </p>
      </div>

      <div class="bg-white p-8 rounded-xl shadow-sm border border-slate-200">
        <div class="text-4xl font-bold text-teal mb-2">100%</div>
        <div class="text-sm font-semibold text-navy uppercase tracking-wide mb-2">
          Hand-Coded
        </div>
        <p class="text-slate-600">
          No templates, no WordPress, no bloated page builders.
        </p>
      </div>
    </div>
  </Section>

  <CTAAboveFooter />
</Layout>
