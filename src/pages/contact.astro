---
import Layout from "../layouts/Layout.astro";
import Heading from "../components/ui/Heading.astro";
import Section from "../components/ui/Section.astro";
import ContactForm from "../components/ContactForm.astro";
import { Mail, Phone, MapPin } from "lucide-astro";
import HeroSecondary from "../components/HeroSecondary.astro";

const pageTitle = "Contact";
const metaDescription = "Have a question about your next web project? Contact Dockside Web Solutions today. Use our contact form to get a quote or schedule a discovery call.";
---

<Layout title={pageTitle} description={metaDescription}>
  <HeroSecondary
    label="Contact Us"
    heading="Talk With Our Team"
    description="Tell us a bit about your project. We’ll follow up with next steps!"
  />

  <Section bg="light">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <div>
        <Heading class="mb-6">Get in Touch</Heading>
        <div class="space-y-8">
          <!-- Email -->
          <div class="flex items-start space-x-4">
            <a
              href="mailto:contact@docksideweb.com"
              class="group flex items-start space-x-4 no-underline"
            >
              <div
                class="bg-teal/10 p-3 rounded-lg transition-colors group-hover:bg-yellow-500/10"
              >
                <Mail
                  class="h-6 w-6 text-teal transition-colors group-hover:text-gold"
                />
              </div>
              <div>
                <h4 class="font-bold text-navy">Email Us</h4>
                <p>contact@docksideweb.com</p>
              </div>
            </a>
          </div>

          <!-- Phone -->
          <div class="flex items-start space-x-4">
            <a
              href="tel:+14438447850"
              class="group flex items-start space-x-4 no-underline"
            >
              <div
                class="bg-teal/10 p-3 rounded-lg transition-colors group-hover:bg-yellow-500/10"
              >
                <Phone
                  class="h-6 w-6 text-teal transition-colors group-hover:text-gold"
                />
              </div>
              <div>
                <h4 class="font-bold text-navy">Call Us</h4>
                <p>+1 (443) 844-7850</p>
              </div>
            </a>
          </div>

          <!-- Charleston -->
          <div class="flex space-x-4">
            <a
              href="tel:+14438447850"
              class="group flex items-center space-x-4 no-underline">
              <div class="bg-teal/10 p-3 rounded-lg transition-colors group-hover:bg-yellow-500/10">
                <MapPin class="h-6 w-6 text-teal transition-colors group-hover:text-gold" />
              </div>
              <h4 class="font-bold text-navy items-center">Charleston, SC</h4>
            </a>
          </div>

          <!-- Baltimore -->
          <div class="flex items-start space-x-4">
            <a
              href="tel:+14438447850"
              class="group flex items-center space-x-4 no-underline"
            >
              <div
                class="bg-teal/10 p-3 rounded-lg transition-colors group-hover:bg-yellow-500/10"
              >
                <MapPin
                  class="h-6 w-6 text-teal transition-colors group-hover:text-gold"
                />
              </div>
              <div>
                <h4 class="font-bold text-navy">Baltimore, MD</h4>
              </div>
            </a>
          </div>
        </div>
      </div>

      <ContactForm />
    </div>
  </Section>
</Layout>
