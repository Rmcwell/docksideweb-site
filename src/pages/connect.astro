---
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
import CTAAboveFooter from "../components/CTAAboveFooter.astro";
import marinaImage from "../assets/hero-marina.webp";
import {
    CheckCircle
  } from "lucide-astro";

---

<Layout>
    <!-- Hero Section -->
    <section class="hero-section relative bg-navy min-h-[75vh] flex items-center overflow-hidden pb-24"
             style={`background-image: url(${marinaImage.src});`} >
  
      <!-- Subtle Pattern Overlay -->
      <div class="absolute inset-0 bg-navy/85"></div>
      <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20" />
  
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 pt-20">
        <div class="max-w-3xl">
          <div class="animate-fade-in-up">
            <div class="flex items-center space-x-2 mb-6">
              <div class="h-0.5 w-12 bg-gold"></div>
              <span
                class="text-gold font-medium uppercase tracking-widest text-sm"
              >
                CHART YOUR COURSE
              </span>
            </div>
            <h1
              class="text-5xl md:text-6xl lg:text-7xl font-heading font-bold text-white leading-tight mb-6"
            >
              Custom Websites Built <br />
              for Small Businesses
            </h1>
            <p class="text-xl text-slate-300 mb-10 leading-relaxed max-w-2xl">
              Built to load fast, show up on Google, and make it easy for customers to contact you.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="/contact">
                <Button variant="primary" size="lg"> Get Started </Button>
              </a>
              <a href="/pricing">
                <Button variant="outline" size="lg" class="text-white border-white">
                  See Pricing
                </Button>
              </a>
            </div>
            <div class="flex flex-wrap gap-8 text-white/80 mt-6">
              <div class="flex items-center space-x-2 trust-indicator opacity-0">
                <CheckCircle class="w-5 h-5 text-gold" />
                <span class="text-sm">Delivered in 3-4 weeks</span>
              </div>
              <div class="flex items-center space-x-2 trust-indicator opacity-0">
                <CheckCircle class="w-5 h-5 text-gold" />
                <span class="text-sm">Upfront, transparent pricing</span>
              </div>
              <div class="flex items-center space-x-2 trust-indicator opacity-0">
                <CheckCircle class="w-5 h-5 text-gold" />
                <span class="text-sm">Support & updates available</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- Wave Divider -->
      <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-0">
        <svg
          class="relative block w-full h-24"
          viewBox="0 0 1440 320"
          preserveAspectRatio="none"
        >
          <path
            fill="#F8FAFC"
            d="M0,160L48,176C96,192,192,224,288,213.3C384,203,480,149,576,149.3C672,149,768,203,864,218.7C960,235,1056,213,1152,186.7C1248,160,1344,128,1392,112L1440,96L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"
          ></path>
        </svg>
      </div>
    </section>


    <CTAAboveFooter />
</Layout>