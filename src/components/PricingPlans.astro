---
import { Check, Plus } from "lucide-astro";
import Button from "./ui/Button.astro";

type Plan = {
  name: string;
  price: string;
  payment: string;
  description: string;
  features: string[];
  optionalFeatures: string[];
  highlighted: boolean;
};

const pricingPlans: Plan[] = [
  {
    name: "The Beacon",
    price: "$79",
    payment: "Per Month",
    description:
      "A simple, professional one‑page site that gets you online fast with hosting, updates, and support built in.",
    features: [
      "Custom single page website",
      "Unlimited minor content edits*",
      "Hosting, domain, & SSL",
      "Delivery in 1-2 weeks",
      "Contact form"
    ],
    optionalFeatures: [],
    highlighted: false,
  },
  {
    name: "The Navigator",
    price: "$165",
    payment: "Per Month",
    description:
      "A complete small-business site with continuous updates so your website stays accurate and ready to convert.",
    features: [
      "Custom website (up to 6 pages)",
      "Unlimited minor content edits*",
      "Hosting, domain, & SSL",
      "Delivery in 3-4 weeks",
      "Contact form"
    ],
    optionalFeatures: ["$100 one-time fee for each extra page"],
    highlighted: true,
  },
  {
    name: "The Vessel",
    price: "$2,750",
    payment: "One Time Cost",
    description:
      "A one-time build for established businesses that want a polished website with no monthly commitment.",
    features: [
      "Custom website (up to 6 pages)",
      "Delivery in 3-4 weeks",
      "All design files and assets"
    ],
    optionalFeatures: [
      "$100 one-time fee for each extra page",
      "$79/month website care plan includes:",
      "Hosting, domain, & SSL",
      "Unlimited minor content edits*",
    ],
    highlighted: false,
  },
];
---

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4 max-w-5xl mx-auto px-4 lg:items-stretch">
  {
    pricingPlans.map((plan) => (
      <div class={plan.highlighted ? "lg:-my-6 relative z-10" : ""}>
        <div
          class={`rounded-2xl flex flex-col h-full transition-shadow duration-300 p-8 ${
            plan.highlighted
              ? "bg-navy text-white shadow-2xl"
              : "bg-light border border-navy/10 text-navy hover:shadow-md"
          }`}
        >
          {/* Badge */}
          {plan.highlighted && (
            <span class="inline-block self-start mb-4 bg-gold text-navy text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full">
              Most Popular
            </span>
          )}

          {/* Name & description */}
          <h3 class="text-2xl font-semibold mb-1">{plan.name}</h3>
          <p class={`text-sm mb-6 leading-relaxed ${plan.highlighted ? "text-white/60" : "text-gray-500"}`}>
            {plan.description}
          </p>

          {/* Price */}
          <div class="mb-6">
            <span class={`text-5xl tracking-tight ${plan.highlighted ? "text-white" : "text-navy"}`}>
              {plan.price}
            </span>
            {plan.price !== "Custom" && (
              <span class={`text-sm ml-2 ${plan.highlighted ? "text-white/60" : "text-gray-500"}`}>
                {plan.payment}
              </span>
            )}
          </div>

          {/* CTA */}
          <a href="/contact/" class="mb-8">
            <Button variant={plan.highlighted ? "primary" : "outline"} class="w-full" >
              Get Started
            </Button>
          </a>

          {/* Features */}
          <div class="flex-1">
            <p class={`text-xs font-semibold uppercase tracking-widest mb-4 ${plan.highlighted ? "text-white/40" : "text-gray-400"}`}>
              What's Included
            </p>
            <div class="space-y-3">
              {plan.features.map((feature) => (
                <div class="flex items-start gap-3">
                  <Check class="h-4 w-4 mt-0.5 shrink-0 text-teal" />
                  <span class={`text-sm leading-snug ${plan.highlighted ? "text-white/60" : "text-gray-500"}`}>
                    {feature}
                  </span>
                </div>
              ))}
            </div>

            {plan.optionalFeatures.length > 0 && (
              <>
                <div class={`border-t my-5 ${plan.highlighted ? "border-white/10" : "border-navy/10"}`} />
                <p class={`text-xs font-semibold uppercase tracking-widest mb-4 ${plan.highlighted ? "text-white/40" : "text-gray-400"}`}>
                  Add-Ons (Optional)
                </p>
                <div class="space-y-3">
                  {plan.optionalFeatures.map((feature) => (
                    <div class="flex items-start gap-3">
                      <Plus class="h-4 w-4 mt-0.5 shrink-0 text-gold" />
                      <span class={`text-sm leading-snug ${plan.highlighted ? "text-white/60" : "text-gray-500"}`}>
                        {feature}
                      </span>
                    </div>
                  ))}
                </div>
              </>
            )}
          </div>
        </div>
      </div>
    ))
  }
</div>

<p class="text-gray-400 text-s text-center px-8 mt-10 lg:mt-12 mx-auto">
  * Minor content edits have a 4-5 business day turnaround and include text and image
  updates only; no new pages or structural layout changes.
</p>