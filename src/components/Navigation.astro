---
import Button from "./ui/Button.astro";
import Logo from "../assets/logo/logo-horizontal-light.svg";

const rawPath = Astro.url.pathname;
const currentPath = rawPath === "/" ? "/" : rawPath.replace(/\/$/, "");

const navLinks = [
  { name: "Home", path: "/" },
  { name: "Services", path: "/services/" },
  { name: "Pricing", path: "/pricing/" },
  { name: "Process", path: "/process/" },
  { name: "Contact", path: "/contact/" },
];
---

<header id="main-header" class="fixed w-full z-50 transition-all duration-500 bg-navy py-4">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center">
      <a href="/" class="flex items-center group">
        <Logo 
          class="h-12 md:h-16 w-auto transition-all duration-300 group-hover:opacity-90" 
          aria-label="Dockside Web Solutions Logo" 
        />
      </a>

      <nav class="hidden md:flex items-center space-x-10">
        {
          navLinks.map((link) => (
            <a href={link.path} class={`text-sm font-semibold tracking-wide uppercase transition-colors hover:text-gold ${currentPath === link.path ? "text-gold" : "text-slate-200"}`}
            >
              {link.name}
            </a>
          ))
        }
        <a href="/contact/">
          <Button variant="primary" size="sm" class="shadow-md hover:shadow-gold/20">
            Get Started
          </Button>
        </a>
      </nav>

      <button
        id="mobile-menu-button"
        class="md:hidden text-white p-2 hover:bg-white/10 rounded-lg transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="menu-icon" class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg id="close-icon" class="h-6 w-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden absolute top-full left-0 w-full bg-navy/98 backdrop-blur-xl border-t border-white/5 shadow-2xl hidden"
  >
    <div class="px-6 py-8 space-y-6">
      {
        navLinks.map((link) => (
          <a
            href={link.path}
            class={`block text-lg font-medium tracking-tight ${
              currentPath === link.path ? "text-gold" : "text-slate-200"
            }`}
          >
            {link.name}
          </a>
        ))
      }
      <a href="/contact/" class="block pt-2">
        <Button variant="primary" class="w-full py-4 text-base">Get Started</Button>
      </a>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 w-full h-px bg-linear-to-r from-transparent via-gold/20 to-transparent"></div>
</header>

<script>
  function handleScroll() {
    const header = document.getElementById("main-header");
    if (!header) return;

    // Use a slightly larger scroll threshold for a smoother "docking" feel
    if (window.scrollY > 50) {
      header.classList.add("bg-navy/95", "backdrop-blur-md", "shadow-xl", "py-3");
      header.classList.remove("py-6");
    } else {
      header.classList.remove("bg-navy/95", "backdrop-blur-md", "shadow-xl", "py-3");
      header.classList.add("py-6");
    }
  }

  function setupMobileMenu() {
    const menuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuIcon = document.getElementById("menu-icon");
    const closeIcon = document.getElementById("close-icon");

    if (!menuButton || !mobileMenu || !menuIcon || !closeIcon) return;

    menuButton.onclick = () => {
      const isHidden = mobileMenu.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden", !isHidden);
      closeIcon.classList.toggle("hidden", isHidden);
      menuButton.setAttribute("aria-expanded", String(!isHidden));
      
      // Prevent body scroll when menu is open
      document.body.style.overflow = isHidden ? "" : "hidden";
    };

    // Close menu when clicking outside
    document.addEventListener("click", (e) => {
      if (!menuButton.contains(e.target as Node) && !mobileMenu.contains(e.target as Node)) {
        mobileMenu.classList.add("hidden");
        menuIcon.classList.remove("hidden");
        closeIcon.classList.add("hidden");
        document.body.style.overflow = "";
      }
    });
  }

  // Initializations
  handleScroll();
  setupMobileMenu();
  window.addEventListener("scroll", handleScroll, { passive: true });

  document.addEventListener("astro:page-load", () => {
    handleScroll();
    setupMobileMenu();
  });
</script>